# --- Runtime ---
ENVIRONMENT=development
DEBUG=true
AUTO_CREATE_TABLES=true

# --- Database (async Postgres). Railway/Heroku-style postgres:// is auto-normalized. ---
DATABASE_URL=postgresql+asyncpg://investwise:investwise@localhost:5432/investwise

# --- Frontend ---
FRONTEND_ORIGIN=http://localhost:5173

# --- SuperAdmin ---
SUPERADMIN_NAME=Eran Ganot
